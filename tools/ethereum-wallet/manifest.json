{
  "name": "Ethereum Wallet",
  "aiTools": {
    "enabled": true,
    "description": "Ethereum 지갑 도구. ETH 잔액 조회, ERC-20 토큰 잔액 및 목록 조회, 가스비 확인. 사용자가 '이더리움 잔액', 'ETH 얼마야', '이더리움 토큰 뭐있어' 등을 물으면 이 도구를 사용하세요.",
    "actions": [
      {
        "name": "getAddress",
        "description": "현재 사용자의 Ethereum 지갑 주소를 조회합니다. 잔액이나 토큰 조회 전에 주소가 필요하면 먼저 이 함수를 호출하세요.",
        "input": {
          "type": "object",
          "properties": {}
        },
        "output": {
          "type": "object",
          "properties": {
            "address": { "type": "string", "description": "Ethereum 지갑 주소 (0x...)" },
            "chain": { "type": "string" }
          }
        }
      },
      {
        "name": "getBalance",
        "description": "Ethereum 지갑의 ETH 잔액을 조회합니다. 사용자가 '이더리움 잔액', 'ETH 얼마야', '이더 잔액' 등을 물으면 사용.",
        "input": {
          "type": "object",
          "required": ["address"],
          "properties": {
            "address": { "type": "string", "description": "이더리움 지갑 주소 (0x...)" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "balance": { "type": "string", "description": "ETH 잔액" },
            "balanceWei": { "type": "string", "description": "Wei 단위 잔액" },
            "symbol": { "type": "string" },
            "chain": { "type": "string" }
          }
        }
      },
      {
        "name": "getTokenBalance",
        "description": "특정 ERC-20 토큰의 잔액을 조회합니다.",
        "input": {
          "type": "object",
          "required": ["address", "tokenAddress"],
          "properties": {
            "address": { "type": "string", "description": "지갑 주소" },
            "tokenAddress": { "type": "string", "description": "토큰 컨트랙트 주소" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "balance": { "type": "string" },
            "symbol": { "type": "string" },
            "decimals": { "type": "number" }
          }
        }
      },
      {
        "name": "getOwnedTokens",
        "description": "지갑이 보유한 모든 ERC-20 토큰 목록을 조회합니다. 사용자가 '이더리움 토큰 뭐있어', '내 토큰 목록' 등을 물으면 사용.",
        "input": {
          "type": "object",
          "required": ["address"],
          "properties": {
            "address": { "type": "string", "description": "지갑 주소" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "tokens": { "type": "array" },
            "count": { "type": "number" }
          }
        }
      },
      {
        "name": "getGasPrice",
        "description": "현재 Ethereum 가스 가격을 조회합니다. 사용자가 '이더리움 가스비', 'ETH 수수료' 등을 물으면 사용.",
        "input": {
          "type": "object",
          "properties": {}
        },
        "output": {
          "type": "object",
          "properties": {
            "gasPrice": { "type": "string" },
            "gasPriceGwei": { "type": "string" }
          }
        }
      },
      {
        "name": "estimateGas",
        "description": "ETH 전송에 필요한 가스비를 예측합니다.",
        "input": {
          "type": "object",
          "required": ["from", "to", "amount"],
          "properties": {
            "from": { "type": "string", "description": "보내는 주소" },
            "to": { "type": "string", "description": "받는 주소" },
            "amount": { "type": "string", "description": "전송할 ETH 수량" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "gasLimit": { "type": "string" },
            "gasFee": { "type": "string" }
          }
        }
      },
      {
        "name": "getTransactionStatus",
        "description": "트랜잭션 해시를 입력받아 현재 상태와 확인 수를 조회합니다.",
        "input": {
          "type": "object",
          "required": ["txHash"],
          "properties": {
            "txHash": { "type": "string", "description": "트랜잭션 해시 (0x...)" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "description": "상태 (confirmed/failed/pending)" },
            "confirmations": { "type": "number", "description": "블록 확인 수" }
          }
        }
      }
    ]
  }
}
