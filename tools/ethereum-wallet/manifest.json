{
  "name": "Ethereum Wallet",
  "aiTools": {
    "enabled": true,
    "description": "Ethereum wallet tool. Query ETH balance, ERC-20 token balances and list, check gas prices. Use this tool when the user asks about Ethereum balance, ETH holdings, or token list.",
    "actions": [
      {
        "name": "getAddress",
        "description": "Get the current user's Ethereum wallet address. Call this first if an address is needed before querying balances or tokens.",
        "input": {
          "type": "object",
          "properties": {}
        },
        "output": {
          "type": "object",
          "properties": {
            "address": { "type": "string", "description": "Ethereum wallet address (0x...)" },
            "chain": { "type": "string" }
          }
        }
      },
      {
        "name": "getBalance",
        "description": "Get the ETH balance of an Ethereum wallet. Use when the user asks about Ethereum balance or ETH holdings.",
        "input": {
          "type": "object",
          "required": ["address"],
          "properties": {
            "address": { "type": "string", "description": "Ethereum wallet address (0x...)" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "balance": { "type": "string", "description": "ETH balance" },
            "balanceWei": { "type": "string", "description": "Balance in Wei" },
            "symbol": { "type": "string" },
            "chain": { "type": "string" }
          }
        }
      },
      {
        "name": "getTokenBalance",
        "description": "Get the balance of a specific ERC-20 token.",
        "input": {
          "type": "object",
          "required": ["address", "tokenAddress"],
          "properties": {
            "address": { "type": "string", "description": "Wallet address" },
            "tokenAddress": { "type": "string", "description": "Token contract address" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "balance": { "type": "string" },
            "symbol": { "type": "string" },
            "decimals": { "type": "number" }
          }
        }
      },
      {
        "name": "getOwnedTokens",
        "description": "Get a list of all ERC-20 tokens held by the wallet. Use when the user asks about their token list or holdings.",
        "input": {
          "type": "object",
          "required": ["address"],
          "properties": {
            "address": { "type": "string", "description": "Wallet address" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "tokens": { "type": "array" },
            "count": { "type": "number" }
          }
        }
      },
      {
        "name": "getGasPrice",
        "description": "Get the current Ethereum gas price. Use when the user asks about Ethereum gas fees or transaction costs.",
        "input": {
          "type": "object",
          "properties": {}
        },
        "output": {
          "type": "object",
          "properties": {
            "gasPrice": { "type": "string" },
            "gasPriceGwei": { "type": "string" }
          }
        }
      },
      {
        "name": "estimateGas",
        "description": "Estimate the gas fee required for an ETH transfer.",
        "input": {
          "type": "object",
          "required": ["from", "to", "amount"],
          "properties": {
            "from": { "type": "string", "description": "Sender address" },
            "to": { "type": "string", "description": "Recipient address" },
            "amount": { "type": "string", "description": "ETH amount to transfer" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "gasLimit": { "type": "string" },
            "gasFee": { "type": "string" }
          }
        }
      },
      {
        "name": "getTransactionStatus",
        "description": "Get the current status and confirmation count for a transaction hash.",
        "input": {
          "type": "object",
          "required": ["txHash"],
          "properties": {
            "txHash": { "type": "string", "description": "Transaction hash (0x...)" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "description": "Status (confirmed/failed/pending)" },
            "confirmations": { "type": "number", "description": "Number of block confirmations" }
          }
        }
      }
    ]
  }
}
