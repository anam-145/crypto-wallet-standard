{
  "name": "Base Wallet",
  "aiTools": {
    "enabled": true,
    "description": "Base L2 지갑 도구. Base 체인의 ETH 잔액, ERC-20 토큰 조회, USDC 잔액 확인. L2라서 가스비가 저렴합니다. 사용자가 'Base 잔액', 'L2 잔액', 'Base USDC' 등을 물으면 이 도구를 사용하세요.",
    "actions": [
      {
        "name": "getAddress",
        "description": "현재 사용자의 Base 지갑 주소를 조회합니다. 잔액이나 토큰 조회 전에 주소가 필요하면 먼저 이 함수를 호출하세요.",
        "input": { "type": "object", "properties": {} },
        "output": {
          "type": "object",
          "properties": {
            "address": { "type": "string", "description": "Base 지갑 주소 (0x...)" },
            "chain": { "type": "string" }
          }
        }
      },
      {
        "name": "getBalance",
        "description": "Base 지갑의 ETH 잔액을 조회합니다. 사용자가 'Base 잔액', 'L2 잔액', 'Base ETH' 등을 물으면 사용.",
        "input": {
          "type": "object",
          "required": ["address"],
          "properties": {
            "address": { "type": "string", "description": "Base 지갑 주소 (0x...)" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "balance": { "type": "string" },
            "balanceWei": { "type": "string" },
            "symbol": { "type": "string" },
            "chain": { "type": "string" }
          }
        }
      },
      {
        "name": "getTokenBalance",
        "description": "Base에서 특정 ERC-20 토큰의 잔액을 조회합니다.",
        "input": {
          "type": "object",
          "required": ["address", "tokenAddress"],
          "properties": {
            "address": { "type": "string", "description": "지갑 주소" },
            "tokenAddress": { "type": "string", "description": "토큰 컨트랙트 주소" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "balance": { "type": "string" },
            "symbol": { "type": "string" },
            "decimals": { "type": "number" }
          }
        }
      },
      {
        "name": "getUSDCBalance",
        "description": "Base의 USDC 잔액을 조회합니다. 사용자가 'Base USDC', 'L2 USDC 잔액' 등을 물으면 사용.",
        "input": {
          "type": "object",
          "required": ["address"],
          "properties": {
            "address": { "type": "string", "description": "지갑 주소" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "balance": { "type": "string" },
            "symbol": { "type": "string" }
          }
        }
      },
      {
        "name": "getOwnedTokens",
        "description": "Base 지갑이 보유한 모든 토큰 목록을 조회합니다.",
        "input": {
          "type": "object",
          "required": ["address"],
          "properties": {
            "address": { "type": "string", "description": "지갑 주소" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "tokens": { "type": "array" },
            "count": { "type": "number" }
          }
        }
      },
      {
        "name": "getGasPrice",
        "description": "Base의 현재 가스 가격을 조회합니다. L2라서 매우 저렴합니다.",
        "input": { "type": "object", "properties": {} },
        "output": {
          "type": "object",
          "properties": {
            "gasPrice": { "type": "string" },
            "gasPriceGwei": { "type": "string" }
          }
        }
      },
      {
        "name": "estimateGas",
        "description": "Base에서 ETH 전송에 필요한 가스비를 예측합니다.",
        "input": {
          "type": "object",
          "required": ["from", "to", "amount"],
          "properties": {
            "from": { "type": "string" },
            "to": { "type": "string" },
            "amount": { "type": "string" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "gasLimit": { "type": "string" },
            "gasFee": { "type": "string" }
          }
        }
      },
      {
        "name": "getTransactionStatus",
        "description": "Base 트랜잭션 상태를 확인합니다.",
        "input": {
          "type": "object",
          "required": ["txHash"],
          "properties": {
            "txHash": { "type": "string" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "description": "상태 (confirmed/failed/pending)" },
            "confirmations": { "type": "number" }
          }
        }
      }
    ]
  }
}
