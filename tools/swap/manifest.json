{
  "name": "Swap",
  "aiTools": {
    "enabled": true,
    "description": "Token swap tool via Uniswap V3. Supports ETH, USDC and other tokens. Compares 4 fee tiers (0.01%, 0.05%, 0.3%, 1%) and auto-selects the optimal pool. Use when the user asks to swap tokens, get a quote, or check exchange rates.",
    "actions": [
      {
        "name": "quote",
        "description": "Get a swap quote. Compares all 4 Uniswap V3 fee tiers and auto-selects the pool with the best output. Use when the user asks for a swap quote, exchange rate, or expected output.",
        "input": {
          "type": "object",
          "required": ["chain", "tokenIn", "tokenOut", "amount"],
          "properties": {
            "chain": { "type": "string", "enum": ["ethereum", "base"], "description": "Chain to execute the swap on" },
            "tokenIn": { "type": "string", "description": "Token to swap from (ETH, WETH, USDC, or token address)" },
            "tokenOut": { "type": "string", "description": "Token to receive" },
            "amount": { "type": "string", "description": "Amount to swap" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "amountOut": { "type": "string", "description": "Expected output amount" },
            "rate": { "type": "string", "description": "Exchange rate" },
            "gasFee": { "type": "string", "description": "Estimated gas fee (ETH)" },
            "bestPool": { "type": "object", "description": "Best pool info" },
            "allPools": { "type": "array", "description": "Comparison of all pools" }
          }
        }
      },
      {
        "name": "compare",
        "description": "Compare swap quotes between Ethereum and Base for the same pair. Recommends the more favorable chain. Use when the user asks which chain is better for a swap.",
        "input": {
          "type": "object",
          "required": ["tokenIn", "tokenOut", "amount"],
          "properties": {
            "tokenIn": { "type": "string", "description": "Token to swap from" },
            "tokenOut": { "type": "string", "description": "Token to receive" },
            "amount": { "type": "string", "description": "Amount to swap" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "ethereum": { "type": "object", "description": "Ethereum quote" },
            "base": { "type": "object", "description": "Base quote" },
            "recommendation": { "type": "string", "description": "Recommended chain" },
            "reason": { "type": "string", "description": "Recommendation reason" }
          }
        }
      },
      {
        "name": "execute",
        "description": "Execute a token swap. Sends an actual transaction to exchange tokens. Use when the user explicitly requests to perform a swap.",
        "input": {
          "type": "object",
          "required": ["chain", "tokenIn", "tokenOut", "amountIn"],
          "properties": {
            "chain": { "type": "string", "enum": ["ethereum", "base"], "description": "Chain to execute the swap on" },
            "tokenIn": { "type": "string", "description": "Token to swap from (ETH, USDC)" },
            "tokenOut": { "type": "string", "description": "Token to receive" },
            "amountIn": { "type": "string", "description": "Amount to swap" },
            "slippage": { "type": "number", "description": "Slippage tolerance (default: 0.5%)" }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "txHash": { "type": "string", "description": "Transaction hash" },
            "explorerUrl": { "type": "string", "description": "Block explorer link" },
            "status": { "type": "string", "description": "Transaction status (success/failed)" },
            "amountIn": { "type": "string", "description": "Amount swapped" },
            "amountOut": { "type": "string", "description": "Amount received" }
          }
        }
      }
    ]
  }
}
