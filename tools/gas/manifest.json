{
  "app_id": "com.anam.gas-tool",
  "type": "app",
  "name": "Gas",
  "version": "1.0.0",
  "icon": "assets/icons/app_icon.png",
  "pages": [
    "pages/index/index"
  ],

  "aiTools": {
    "enabled": true,
    "description": "멀티체인 가스비 조회 및 비교 도구. Ethereum, Base의 실시간 가스비를 조회하고 최적의 체인을 추천합니다. USD 환산 포함. 사용자가 '가스비 얼마야', '어느 체인이 싸?', '지금 이더리움 수수료', '트랜잭션 비용 비교' 등을 물으면 이 도구를 사용하세요.",
    "actions": [
      {
        "name": "getAllGasPrices",
        "description": "모든 체인(Ethereum, Base)의 가스비를 한번에 조회합니다. USD 환산 포함. 사용자가 '전체 가스비', '모든 체인 수수료' 등을 물으면 사용.",
        "input": {
          "type": "object",
          "properties": {}
        },
        "output": {
          "type": "object",
          "properties": {
            "ethereum": { "type": "object", "description": "Ethereum 가스비 정보" },
            "base": { "type": "object", "description": "Base 가스비 정보" },
            "timestamp": { "type": "string" }
          }
        }
      },
      {
        "name": "getChainGas",
        "description": "특정 체인의 가스비를 조회합니다. 사용자가 '이더리움 가스비', 'Base 수수료' 등을 물으면 사용.",
        "input": {
          "type": "object",
          "required": ["chain"],
          "properties": {
            "chain": {
              "type": "string",
              "enum": ["ethereum", "base"],
              "description": "조회할 체인"
            }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "chain": { "type": "string" },
            "gasPriceGwei": { "type": "string" },
            "ethPriceUSD": { "type": "number" },
            "estimates": { "type": "object", "description": "작업별 예상 수수료" }
          }
        }
      },
      {
        "name": "compareGas",
        "description": "Ethereum과 Base의 특정 작업 가스비를 비교합니다. 사용자가 '어느 체인이 싸', '가스비 비교' 등을 물으면 사용.",
        "input": {
          "type": "object",
          "properties": {
            "operation": {
              "type": "string",
              "enum": ["transfer", "swap"],
              "default": "transfer",
              "description": "비교할 작업 유형"
            }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "operation": { "type": "string" },
            "ethereum": { "type": "object" },
            "base": { "type": "object" },
            "comparison": {
              "type": "object",
              "properties": {
                "cheaperChain": { "type": "string" },
                "savingsPercent": { "type": "string" },
                "recommendation": { "type": "string" }
              }
            }
          }
        }
      },
      {
        "name": "recommendChain",
        "description": "거래 금액과 작업 유형을 고려하여 최적의 체인을 추천합니다. 사용자가 '어디서 하는게 나아', '추천해줘' 등을 물으면 사용.",
        "input": {
          "type": "object",
          "properties": {
            "operation": {
              "type": "string",
              "enum": ["transfer", "swap"],
              "default": "transfer",
              "description": "작업 유형"
            },
            "amount": {
              "type": "string",
              "default": "1",
              "description": "거래 금액 (ETH)"
            }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "recommendation": {
              "type": "object",
              "properties": {
                "chain": { "type": "string", "description": "추천 체인" },
                "reason": { "type": "string", "description": "추천 이유" }
              }
            }
          }
        }
      }
    ]
  }
}
